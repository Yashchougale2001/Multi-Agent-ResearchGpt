# Groq Configuration (FREE TIER)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile
# Alternative models: mixtral-8x7b-32768, llama-3.1-8b-instant, gemma-7b-it

# Embedding Model (Free - using sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Alternative: all-mpnet-base-v2, multi-qa-mpnet-base-dot-v1

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=research_docs

# Redis
REDIS_URL=redis://localhost:6379

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Research Settings
MAX_SEARCH_RESULTS=10
MAX_SUBTASKS=5
RETRIEVAL_TOP_K=5
MAX_TOKENS=8000
TEMPERATURE=0.7